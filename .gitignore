# modloader.gd is a build artifact, generated by build.sh from src/*.gd.
# It's attached to GitHub releases as a downloadable asset, not committed.
# Devs run ./build.sh locally to produce it when testing in-game.
modloader.gd
modloader.gd.tmp

# Build script temp files
*.tmp

# Local working notes and staging -- never part of a release.
.research/
.fable_fixes/
release/
